{
    "compilerOptions": {
      "moduleResolution": "nodenext",
      "module": "nodenext",  
      "strict": true,                           
      "esModuleInterop": true,                  
      "skipLibCheck": true,                     
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist/ts/",
      "declaration": true,
      "stripInternal": true,
      "rootDir": "./src/ts/",
      "target": "es2024",
      "lib":["ES2024","dom"]   
    },
    "include": ["./src/ts/**/*"],
    "exclude": ["node_modules"]
}
